<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_rounded_top_white"
    android:paddingTop="24dp"
    android:paddingBottom="24dp">
    <ImageView
    android:id="@+id/btnCloseWorkspaces"
    android:layout_width="32dp"
    android:layout_height="32dp"
    android:layout_marginEnd="20dp"
    android:background="@drawable/bg_circle_light_grey"
    android:padding="8dp"
    app:srcCompat="@drawable/close_icon"
    app:tint="@color/text_gray_secondary"
    app:layout_constraintTop_toTopOf="parent"
    app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvWorkspacesTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Workspaces"
        android:textColor="@color/black"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/btnCloseWorkspaces"
        app:layout_constraintBottom_toBottomOf="@id/btnCloseWorkspaces" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constrainedHeight="true"
        app:layout_constraintHeight_max="350dp"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/btnCloseWorkspaces"
        app:layout_constraintBottom_toTopOf="@id/dividerLine">

        <LinearLayout
            android:id="@+id/llWorkspacesList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingBottom="8dp">

            <include layout="@layout/item_workspace_row" />
            <include layout="@layout/item_workspace_row" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <View
        android:id="@+id/dividerLine"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/workspace_divider_grey"
        app:layout_constraintTop_toBottomOf="@id/scrollContainer"
        app:layout_constraintBottom_toTopOf="@id/btnCreateWorkspace"
        android:layout_marginBottom="16dp" />

    <LinearLayout
        android:id="@+id/btnCreateWorkspace"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginHorizontal="20dp"
        android:background="@drawable/bg_button_primary"
        android:gravity="center"
        android:orientation="horizontal"
        android:elevation="2dp"
        app:layout_constraintTop_toBottomOf="@id/dividerLine"
        app:layout_constraintBottom_toBottomOf="parent">

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            app:srcCompat="@drawable/plus_icon"
            app:tint="@color/white" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="Create Workspace"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>