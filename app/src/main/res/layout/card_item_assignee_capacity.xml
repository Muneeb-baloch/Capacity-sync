<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true"
    android:paddingHorizontal="16dp"
    android:paddingVertical="12dp">

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/ivAssigneeAvatar"
        android:layout_width="40dp"
        android:layout_height="40dp"
        app:srcCompat="@drawable/profile_icon"
        app:shapeAppearanceOverlay="@style/CircleImage"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvAssigneeName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="8dp"
        android:text="Alex Johnson"
        android:textColor="@color/black"
        android:textSize="15sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@id/tvAssigneeRole"
        app:layout_constraintEnd_toStartOf="@+id/cvCapacityBadge"
        app:layout_constraintStart_toEndOf="@id/ivAssigneeAvatar"
        app:layout_constraintTop_toTopOf="@id/ivAssigneeAvatar"
        app:layout_setVerticalChainStyle="packed" />

    <TextView
        android:id="@+id/tvAssigneeRole"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="8dp"
        android:text="Senior Developer"
        android:textColor="#8E8E93"
        android:textSize="12sp"
        app:layout_constraintBottom_toBottomOf="@id/ivAssigneeAvatar"
        app:layout_constraintEnd_toStartOf="@+id/cvCapacityBadge"
        app:layout_constraintStart_toEndOf="@id/ivAssigneeAvatar"
        app:layout_constraintTop_toBottomOf="@id/tvAssigneeName" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cvCapacityBadge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="#E8F5E9"
        app:cardCornerRadius="8dp"
        app:cardElevation="0dp"
        app:strokeWidth="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="8dp"
            android:paddingVertical="4dp"
            android:gravity="center_vertical">

            <View
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:background="@drawable/bg_online_dot" />
            <TextView

            android:id="@+id/tvAvailableHours"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:text="12h free"
            android:textColor="#2E7D32"
            android:textSize="12sp"
            android:textStyle="bold" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>