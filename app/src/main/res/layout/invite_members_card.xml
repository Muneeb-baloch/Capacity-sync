<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_rounded_bottom_sheet"
    android:paddingHorizontal="20dp"
    android:paddingTop="24dp"
    android:paddingBottom="32dp">

    <TextView
        android:id="@+id/tvInviteTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Invite members"
        android:textColor="@color/black"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/btnCloseInvite"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@drawable/close_icon"
        app:tint="@color/black"
        app:layout_constraintBottom_toBottomOf="@id/tvInviteTitle"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/tvInviteTitle" />

    <LinearLayout
        android:id="@+id/llEmailInputContainer"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="24dp"
        android:background="@drawable/bg_search_bar"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toBottomOf="@id/tvInviteTitle">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/inbox_icon"
            app:tint="@color/text_gray_secondary" />

        <EditText
            android:id="@+id/etInviteEmail"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginStart="12dp"
            android:background="@null"
            android:hint="Email"
            android:inputType="textEmailAddress"
            android:textColor="@color/black"
            android:textColorHint="@color/text_gray_secondary"
            android:textSize="16sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/btnSubmitInvite"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_search_bar"
        android:gravity="center"
        android:text="Invite"
        android:textColor="#C7C7CC"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/llEmailInputContainer" />

</androidx.constraintlayout.widget.ConstraintLayout>