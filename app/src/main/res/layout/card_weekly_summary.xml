<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    app:cardBackgroundColor="@color/glass_card_bg_tint"
    app:cardCornerRadius="24dp"
    app:cardElevation="0dp"
    app:strokeWidth="0dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp">

        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:background="@drawable/glass_reflection"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvEditCapacity"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Edit"
            android:textColor="@color/workspace_primary_purple"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <FrameLayout
            android:id="@+id/flProgressRing"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvEditCapacity">

            <com.google.android.material.progressindicator.CircularProgressIndicator
                android:id="@+id/progressWeekly"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:progress="80"
                app:indicatorColor="@color/workspace_primary_purple"
                app:indicatorSize="56dp"
                app:trackColor="@color/workspace_purple_tint_medium"
                app:trackCornerRadius="8dp"
                app:trackThickness="6dp" />

            <TextView
                android:id="@+id/tvRingTotal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="32h"
                android:textColor="@color/primary_text_grey"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium" />
        </FrameLayout>

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/ivSummaryAvatar"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/profile_icon"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:shapeAppearanceOverlay="@style/CircleImage" />

        <TextView
            android:id="@+id/tvWorkspaceContext"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="My Capacity • Alpha Team"
            android:textColor="@color/text_gray_secondary"
            android:textSize="12sp"
            app:layout_constraintBottom_toBottomOf="@id/ivSummaryAvatar"
            app:layout_constraintEnd_toStartOf="@id/tvEditCapacity"
            app:layout_constraintStart_toEndOf="@id/ivSummaryAvatar"
            app:layout_constraintTop_toTopOf="@id/ivSummaryAvatar" />

        <TextView
            android:id="@+id/tvDateRange"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Apr 7 - Apr 14"
            android:textColor="@color/primary_text_grey"
            android:textSize="18sp"
            android:fontFamily="sans-serif-medium"
            app:layout_constraintEnd_toStartOf="@id/flProgressRing"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/ivSummaryAvatar" />

        <TextView
            android:id="@+id/tvHealthStatus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="8 hours remaining"
            android:textColor="@color/health_green"
            android:textSize="12sp"
            app:layout_constraintEnd_toStartOf="@id/flProgressRing"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvDateRange" />

        <LinearLayout
            android:id="@+id/llMiniWeek"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvHealthStatus">

            <TextView android:id="@+id/dayMon" android:layout_width="26dp" android:layout_height="26dp" android:gravity="center" android:text="M" android:textColor="@color/text_gray_inactive" android:textSize="10sp" android:textStyle="bold" />
            <TextView android:id="@+id/dayTue" android:layout_width="26dp" android:layout_height="26dp" android:layout_marginStart="6dp" android:gravity="center" android:text="T" android:textColor="@color/text_gray_inactive" android:textSize="10sp" android:textStyle="bold" />
            <TextView android:id="@+id/dayWed" android:layout_width="26dp" android:layout_height="26dp" android:layout_marginStart="6dp" android:gravity="center" android:text="W" android:textColor="@color/text_gray_inactive" android:textSize="10sp" android:textStyle="bold" />
            <TextView android:id="@+id/dayThu" android:layout_width="26dp" android:layout_height="26dp" android:layout_marginStart="6dp" android:gravity="center" android:text="T" android:textColor="@color/text_gray_inactive" android:textSize="10sp" android:textStyle="bold" />
            <TextView android:id="@+id/dayFri" android:layout_width="26dp" android:layout_height="26dp" android:layout_marginStart="6dp" android:gravity="center" android:text="F" android:textColor="@color/text_gray_inactive" android:textSize="10sp" android:textStyle="bold" />
            <TextView android:id="@+id/daySat" android:layout_width="26dp" android:layout_height="26dp" android:layout_marginStart="6dp" android:gravity="center" android:text="S" android:textColor="@color/text_gray_inactive" android:textSize="10sp" android:textStyle="bold" />
            <TextView android:id="@+id/daySun" android:layout_width="26dp" android:layout_height="26dp" android:layout_marginStart="6dp" android:gravity="center" android:text="S" android:textColor="@color/text_gray_inactive" android:textSize="10sp" android:textStyle="bold" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>