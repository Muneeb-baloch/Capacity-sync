<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingVertical="12dp"> <com.google.android.material.card.MaterialCardView
    android:id="@+id/cardWorkspaceAvatar"
    android:layout_width="36dp"
    android:layout_height="36dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@color/workspace_avatar_green"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintTop_toTopOf="parent"
    app:layout_constraintBottom_toBottomOf="parent">

    <TextView
        android:id="@+id/tvWorkspaceInitial"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:text="W"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:textStyle="bold"/>
</com.google.android.material.card.MaterialCardView>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginStart="16dp" android:layout_marginEnd="16dp"
        app:layout_constraintStart_toEndOf="@id/cardWorkspaceAvatar"
        app:layout_constraintEnd_toStartOf="@id/ivWorkspaceCheckmark"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <TextView
            android:id="@+id/tvWorkspaceName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Workspace Name"
            android:textColor="@color/black"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/tvWorkspaceDetails"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1 member • Owner"
            android:textColor="@color/workspace_text_muted"
            android:textSize="13sp"
            android:layout_marginTop="2dp"/>
    </LinearLayout>

    <ImageView
        android:id="@+id/ivWorkspaceCheckmark"
        android:layout_width="20dp"
        android:layout_height="20dp"
        app:srcCompat="@drawable/check_circle"
        app:tint="@null"
        android:visibility="invisible"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>